import java.io.*;
import java.util.*;
public class Solution {
 public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
    ArrayList<Integer> list = new ArrayList<>();
       String line = sc.nextLine();
        String[] arr = line.split(" ");
     for (String s : arr) {
            list.add(Integer.parseInt(s));
        }
   int k = sc.nextInt();
    int count = 0;
        int n = list.size();
    for (int i = 0; i < n; i++) {
            int sum = 0;
      for (int j = i; j < n; j++) {
                sum += list.get(j);
      if (sum == k) {
                    count++;
                }
            }
        }

   System.out.println("The count of the subarray whereas equals to the target is : " + count);
    }
}
