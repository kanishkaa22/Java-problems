class Solution {
    public int[] shuffle(int[] nums, int n) {
        
        int[] ans = new int[2 * n];

        int j = n; // second half starting index

        for(int i = 0; i < n; i++) {
            ans[2*i] = nums[i];     // x values
            ans[2*i + 1] = nums[j]; // y values
            j++;
        }

        return ans;
    }
}
