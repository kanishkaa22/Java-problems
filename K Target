import java.io.*;
import java.util.*;

public class Solution {
public static void main(String[] args) {
Scanner sc = new Scanner(System.in);
  int n = sc.nextInt();
  int target = sc.nextInt();
  int arr[] = new int[n];
  int count = -1;
  for(int i=0;i<n;i++){
    arr[i]=sc.nextInt();
      if(arr[i]==target){
    count++;
       }
   } 
     System.out.print(count);
     }
         }
